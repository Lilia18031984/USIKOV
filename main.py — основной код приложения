import tkinter as tk
from tkinter import ttk, messagebox
import json
import os
from datetime import datetime, timedelta

class ExpenseTracker:
    def __init__(self, root):
        self.root = root
        self.root.title("Expense Tracker - Трекер расходов")
        self.root.geometry("1200x750")
        self.root.resizable(True, True)

        # Файл для хранения расходов
        self.expenses_file = "expenses.json"
        self.expenses = self.load_expenses()
        
        # Категории расходов
        self.categories = ["Еда", "Транспорт", "Развлечения", "Жильё", "Коммунальные услуги", 
                          "Здоровье", "Одежда", "Образование", "Подарки", "Другое"]
        
        # Создание интерфейса
        self.create_widgets()
        
        # Отображение всех расходов
        self.display_expenses()
        
        # Обновление общей суммы
        self.update_total()

    def load_expenses(self):
        """Загрузка расходов из JSON файла"""
        default_expenses = [
            {
                "date": "2024-12-20",
                "amount": 850.50,
                "category": "Еда",
                "description": "Продукты в супермаркете",
                "added_date": "2024-12-20 10:30:00"
            },
            {
                "date": "2024-12-21",
                "amount": 300.00,
                "category": "Транспорт",
                "description": "Метро и такси",
                "added_date": "2024-12-21 14:20:00"
            },
            {
                "date": "2024-12-22",
                "amount": 1200.00,
                "category": "Развлечения",
                "description": "Кино с друзьями",
                "added_date": "2024-12-22 18:45:00"
            },
            {
                "date": "2024-12-23",
                "amount": 2500.00,
                "category": "Жильё",
                "description": "Аренда квартиры",
                "added_date": "2024-12-23 09:00:00"
            },
            {
                "date": "2024-12-24",
                "amount": 450.00,
                "category": "Еда",
                "description": "Обед в кафе",
                "added_date": "2024-12-24 13:15:00"
            }
        ]
        
        if os.path.exists(self.expenses_file):
            try:
                with open(self.expenses_file, 'r', encoding='utf-8') as f:
                    expenses = json.load(f)
                    if expenses:
                        return expenses
            except:
                pass
        
        self.save_expenses(default_expenses)
        return default_expenses

    def save_expenses(self, expenses=None):
        """Сохранение расходов в JSON файл"""
        if expenses is None:
            expenses = self.expenses
        with open(self.expenses_file, 'w', encoding='utf-8') as f:
            json.dump(expenses, f, indent=4, ensure_ascii=False)

