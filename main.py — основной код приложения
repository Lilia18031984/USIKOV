    def validate_year(self, year_str):
        """Проверка года"""
        try:
            year = int(year_str)
            current_year = datetime.now().year
            if 1888 <= year <= current_year:
                return True, year
            return False, None
        except ValueError:
            return False, None

    def validate_rating(self, rating_str):
        """Проверка рейтинга"""
        try:
            rating = float(rating_str)
            if 0 <= rating <= 10:
                return True, rating
            return False, None
        except ValueError:
            return False, None

    def add_movie(self):
        """Добавление фильма"""
        title = self.title_entry.get().strip()
        genre = self.genre_entry.get().strip()
        year_str = self.year_entry.get().strip()
        rating_str = self.rating_entry.get().strip()
        
        # Валидация
        if not title:
            messagebox.showerror("Ошибка", "Введите название фильма!")
            return
        
        if not genre:
            messagebox.showerror("Ошибка", "Введите жанр!")
            return
        
        valid_year, year = self.validate_year(year_str)
        if not valid_year:
            messagebox.showerror("Ошибка", "Год должен быть числом от 1888 до текущего!")
            return
        
        valid_rating, rating = self.validate_rating(rating_str)
        if not valid_rating:
            messagebox.showerror("Ошибка", "Рейтинг должен быть числом от 0 до 10!")
            return
        
        # Проверка дубликата
        for movie in self.movies:
            if movie["title"].lower() == title.lower() and movie["year"] == year:
                if not messagebox.askyesno("Предупреждение", 
                    f"Фильм '{title}' ({year}) уже существует. Добавить как отдельную запись?"):
                    return
        
        # Добавление
        movie = {
            "title": title,
            "genre": genre,
            "year": year,
            "rating": rating,
            "added_date": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        }
        
        self.movies.append(movie)
        self.save_movies()
        self.update_genres()
        self.display_movies()
        self.update_stats()
        self.clear_fields()
        
        self.status_var.set(f"Фильм '{title}' добавлен")
        messagebox.showinfo("Успех", f"Фильм '{title}' добавлен!")

    def display_movies(self, movies=None):
        """Отображение фильмов в таблице"""
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        display_movies = movies if movies is not None else self.movies
        
        for movie in sorted(display_movies, key=lambda x: x["year"], reverse=True):
            self.tree.insert("", tk.END, values=(
                movie["title"],
                movie["genre"],
                movie["year"],
                f"{movie['rating']:.1f}",
                movie["added_date"]
            ))

    def filter_movies(self):
        """Фильтрация фильмов"""
        selected_genre = self.genre_filter.get()
        year_from_str = self.year_from.get().strip()
        year_to_str = self.year_to.get().strip()
        
        filtered = self.movies.copy()
        
        # Фильтр по жанру
        if selected_genre != "Все":
            filtered = [m for m in filtered if m["genre"] == selected_genre]
        
        # Фильтр по году
        if year_from_str:
            valid, year_from = self.validate_year(year_from_str)
            if valid:
                filtered = [m for m in filtered if m["year"] >= year_from]
            else:
                messagebox.showerror("Ошибка", "Неверный формат года 'от'!")
                return
        
        if year_to_str:
            valid, year_to = self.validate_year(year_to_str)
            if valid:
                filtered = [m for m in filtered if m["year"] <= year_to]
            else:
                messagebox.showerror("Ошибка", "Неверный формат года 'до'!")
                return
        
        self.display_movies(filtered)
        self.update_stats(filtered)
        
        filter_info = []
        if selected_genre != "Все":
            filter_info.append(f"жанр: {selected_genre}")
        if year_from_str:
            filter_info.append(f"год ≥ {year_from_str}")
        if year_to_str:
            filter_info.append(f"год ≤ {year_to_str}")
        
        if filter_info:
            self.status_var.set(f"Найдено {len(filtered)} фильмов ({', '.join(filter_info)})")
        else:
            self.status_var.set(f"Всего фильмов: {len(filtered)}")

    def reset_filters(self):
        """Сброс фильтров"""
        self.genre_filter.set("Все")
        self.year_from.delete(0, tk.END)
        self.year_to.delete(0, tk.END)
        self.display_movies()
        self.update_stats()
        self.status_var.set("Фильтры сброшены")

    def update_stats(self, movies=None):
        """Обновление статистики"""
        if movies is None:
            movies = self.movies
        
        total = len(movies)
        self.total_label.config(text=f"Фильмов: {total}")
        
        if total > 0:
            avg_rating = sum(m["rating"] for m in movies) / total
            best_rating = max(m["rating"] for m in movies)
            self.avg_rating_label.config(text=f"Средний рейтинг: {avg_rating:.2f}")
            self.best_label.config(text=f"Лучший рейтинг: {best_rating:.1f}")
        else:
            self.avg_rating_label.config(text="Средний рейтинг: 0")
            self.best_label.config(text="Лучший рейтинг: 0")

    def update_genres(self):
        """Обновление списка жанров"""
        self.genres = self.get_unique_genres()
        self.genre_filter['values'] = self.genres

    def delete_movie(self):
        """Удаление фильма"""
        selected = self.tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите фильм для удаления!")
            return
        
        item = self.tree.item(selected[0])
        values = item['values']
        
        for i, movie in enumerate(self.movies):
            if (movie["title"] == values[0] and movie["year"] == values[2]):
                if messagebox.askyesno("Подтверждение", f"Удалить фильм '{movie['title']}' ({movie['year']})?"):
                    del self.movies[i]
                    self.save_movies()
                    self.update_genres()
                    self.display_movies()
                    self.update_stats()
                    self.status_var.set(f"Фильм '{movie['title']}' удалён")
                    break

    def edit_movie(self):
        """Редактирование фильма"""
        selected = self.tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите фильм для редактирования!")
            return
        
        item = self.tree.item(selected[0])
        values = item['values']
        
        for i, movie in enumerate(self.movies):
            if movie["title"] == values[0] and movie["year"] == values[2]:
                self.open_edit_window(movie, i)
                break

    def open_edit_window(self, movie, index):
        """Окно редактирования"""
        edit_window = tk.Toplevel(self.root)
        edit_window.title("Редактирование фильма")
        edit_window.geometry("400x400")
        edit_window.resizable(False, False)
        edit_window.transient(self.root)
        edit_window.grab_set()
        
        ttk.Label(edit_window, text="Название:", font=("Arial", 10, "bold")).pack(pady=(15, 5))
        title_edit = ttk.Entry(edit_window, width=40, font=("Arial", 10))
        title_edit.insert(0, movie["title"])
        title_edit.pack(pady=(0, 10))
        
        ttk.Label(edit_window, text="Жанр:", font=("Arial", 10, "bold")).pack(pady=(5, 5))
        genre_edit = ttk.Entry(edit_window, width=40, font=("Arial", 10))
        genre_edit.insert(0, movie["genre"])
        genre_edit.pack(pady=(0, 10))
        
        ttk.Label(edit_window, text="Год:", font=("Arial", 10, "bold")).pack(pady=(5, 5))
        year_edit = ttk.Entry(edit_window, width=40, font=("Arial", 10))
        year_edit.insert(0, str(movie["year"]))
        year_edit.pack(pady=(0, 10))
        
        ttk.Label(edit_window, text="Рейтинг (0-10):", font=("Arial", 10, "bold")).pack(pady=(5, 5))
        rating_edit = ttk.Entry(edit_window, width=40, font=("Arial", 10))
        rating_edit.insert(0, str(movie["rating"]))
        rating_edit.pack(pady=(0, 20))
        
        def save():
            new_title = title_edit.get().strip()
            new_genre = genre_edit.get().strip()
            new_year_str = year_edit.get().strip()
            new_rating_str = rating_edit.get().strip()
            
            if not new_title:
                messagebox.showerror("Ошибка", "Введите название!")
                return
            
            if not new_genre:
                messagebox.showerror("Ошибка", "Введите жанр!")
                return
            
            valid_year, new_year = self.validate_year(new_year_str)
            if not valid_year:
                messagebox.showerror("Ошибка", "Неверный год!")
                return
            
            valid_rating, new_rating = self.validate_rating(new_rating_str)
            if not valid_rating:
                messagebox.showerror("Ошибка", "Неверный рейтинг!")
                return
            
            self.movies[index] = {
                "title": new_title,
                "genre": new_genre,
                "year": new_year,
                "rating": new_rating,
                "added_date": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            }
            
            self.save_movies()
            self.update_genres()
            self.display_movies()
            self.update_stats()
            edit_window.destroy()
            self.status_var.set(f"Фильм '{new_title}' обновлён")
            messagebox.showinfo("Успех", "Фильм обновлён!")
        
        ttk.Button(edit_window, text="💾 Сохранить", command=save).pack(pady=(10, 5))
        ttk.Button(edit_window, text="❌ Отмена", command=edit_window.destroy).pack()

    def clear_fields(self):
        """Очистка полей"""
        self.title_entry.delete(0, tk.END)
        self.genre_entry.delete(0, tk.END)
        self.year_entry.delete(0, tk.END)
        self.rating_entry.delete(0, tk.END)

