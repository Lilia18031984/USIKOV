    def on_period_change(self, event=None):
        """Обработка изменения выбранного периода"""
        period = self.period_filter.get()
        
        if period == "Произвольный":
            self.start_date_frame.pack(side=tk.LEFT, padx=(0, 10))
            self.end_date_frame.pack(side=tk.LEFT)
            self.apply_date_btn.pack(side=tk.LEFT, padx=(10, 0))
            # Заполнение дат по умолчанию
            if not self.start_date_entry.get():
                self.start_date_entry.insert(0, (datetime.now() - timedelta(days=7)).strftime("%Y-%m-%d"))
            if not self.end_date_entry.get():
                self.end_date_entry.insert(0, datetime.now().strftime("%Y-%m-%d"))
        else:
            self.start_date_frame.pack_forget()
            self.end_date_frame.pack_forget()
            self.apply_date_btn.pack_forget()
            self.filter_and_calculate()

    def filter_and_calculate(self):
        """Фильтрация расходов и подсчёт суммы"""
        # Получение фильтров
        selected_category = self.category_filter.get()
        period = self.period_filter.get()
        
        filtered_expenses = self.expenses.copy()
        
        # Фильтр по категории
        if selected_category != "Все":
            filtered_expenses = [e for e in filtered_expenses if e["category"] == selected_category]
        
        # Фильтр по дате
        today = datetime.now().date()
        
        if period == "Сегодня":
            filtered_expenses = [e for e in filtered_expenses if e["date"] == today.strftime("%Y-%m-%d")]
        
        elif period == "Вчера":
            yesterday = today - timedelta(days=1)
            filtered_expenses = [e for e in filtered_expenses if e["date"] == yesterday.strftime("%Y-%m-%d")]
        
        elif period == "Эта неделя":
            start_of_week = today - timedelta(days=today.weekday())
            filtered_expenses = [e for e in filtered_expenses 
                               if datetime.strptime(e["date"], "%Y-%m-%d").date() >= start_of_week]
        
        elif period == "Этот месяц":
            filtered_expenses = [e for e in filtered_expenses 
                               if e["date"].startswith(today.strftime("%Y-%m"))]
        
        elif period == "Произвольный":
            start_date = self.start_date_entry.get().strip()
            end_date = self.end_date_entry.get().strip()
            
            if start_date:
                try:
                    start = datetime.strptime(start_date, "%Y-%m-%d").date()
                    filtered_expenses = [e for e in filtered_expenses 
                                       if datetime.strptime(e["date"], "%Y-%m-%d").date() >= start]
                except ValueError:
                    messagebox.showerror("Ошибка", "Неверный формат начальной даты!")
                    return
            
            if end_date:
                try:
                    end = datetime.strptime(end_date, "%Y-%m-%d").date()
                    filtered_expenses = [e for e in filtered_expenses 
                                       if datetime.strptime(e["date"], "%Y-%m-%d").date() <= end]
                except ValueError:
                    messagebox.showerror("Ошибка", "Неверный формат конечной даты!")
                    return
        
        # Подсчёт суммы
        total = sum(e["amount"] for e in filtered_expenses)
        self.total_amount_label.config(text=f"{total:,.2f} ₽")
        
        # Отображение отфильтрованных расходов
        self.display_expenses(filtered_expenses)
        
        # Обновление статуса
        filter_info = []
        if selected_category != "Все":
            filter_info.append(f"категория: {selected_category}")
        if period != "Все время":
            filter_info.append(f"период: {period.lower()}")
        
        if filter_info:
            self.status_var.set(f"Найдено {len(filtered_expenses)} расходов на сумму {total:,.2f} ₽ ({', '.join(filter_info)})")
        else:
            self.status_var.set(f"Всего расходов: {len(filtered_expenses)} на сумму {total:,.2f} ₽")

    def reset_filters(self):
        """Сброс всех фильтров"""
        self.category_filter.set("Все")
        self.period_filter.set("Все время")
        self.start_date_entry.delete(0, tk.END)
        self.end_date_entry.delete(0, tk.END)
        self.start_date_frame.pack_forget()
        self.end_date_frame.pack_forget()
        self.apply_date_btn.pack_forget()
        self.display_expenses()
        self.update_total()
        self.update_fast_stats()
        self.status_var.set(f"Фильтры сброшены. Всего расходов: {len(self.expenses)}")

    def display_expenses(self, expenses_to_display=None):
        """Отображение расходов в таблице"""
        # Очистка таблицы
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        # Если передан отфильтрованный список, используем его, иначе все расходы
        display_expenses = expenses_to_display if expenses_to_display is not None else self.expenses
        
        # Сортировка по дате (новые сверху)
        display_expenses = sorted(display_expenses, key=lambda x: x["date"], reverse=True)
        
        # Добавление расходов в таблицу
        for expense in display_expenses:
            description = expense.get("description", "")
            if len(description) > 50:
                description = description[:47] + "..."
            
            self.tree.insert("", tk.END, values=(
                expense["date"],
                expense["category"],
                f"{expense['amount']:.2f}",
                description,
                expense.get("added_date", "")
            ))

    def update_total(self):
        """Обновление общей суммы всех расходов"""
        total = sum(e["amount"] for e in self.expenses)
        self.update_fast_stats()

    def update_fast_stats(self):
        """Обновление быстрой статистики"""
        today = datetime.now().date()
        today_str = today.strftime("%Y-%m-%d")
        
        # Расходы сегодня
        today_total = sum(e["amount"] for e in self.expenses if e["date"] == today_str)
        self.today_total_label.config(text=f"Расходы сегодня: {today_total:.2f} ₽")
        
        # Расходы за неделю
        start_of_week = today - timedelta(days=today.weekday())
        week_total = sum(e["amount"] for e in self.expenses 
                        if datetime.strptime(e["date"], "%Y-%m-%d").date() >= start_of_week)
        self.week_total_label.config(text=f"Расходы за неделю: {week_total:.2f} ₽")
        
        # Расходы за месяц
        month_total = sum(e["amount"] for e in self.expenses 
                         if e["date"].startswith(today.strftime("%Y-%m")))
        self.month_total_label.config(text=f"Расходы за месяц: {month_total:.2f} ₽")

    def validate_date(self, date_str):
        """Проверка корректности формата даты"""
        try:
            datetime.strptime(date_str, "%Y-%m-%d")
            return True
        except ValueError:
            return False

    def add_expense(self):
        """Добавление нового расхода"""
        # Получение данных
        amount_str = self.amount_entry.get().strip()
        category = self.category_combo.get()
        date = self.date_entry.get().strip()
        description = self.desc_text.get("1.0", tk.END).strip()
        
        # Валидация суммы
        if not amount_str:
            messagebox.showerror("Ошибка", "Введите сумму расхода!")
            return
        
        try:
            amount = float(amount_str)
            if amount <= 0:
                messagebox.showerror("Ошибка", "Сумма должна быть положительным числом!")
                return
        except ValueError:
            messagebox.showerror("Ошибка", "Сумма должна быть числом!")
            return
        
        # Валидация категории
        if not category or category == "Выберите категорию":
            messagebox.showerror("Ошибка", "Выберите категорию!")
            return
        
        # Валидация даты
        if not date:
            messagebox.showerror("Ошибка", "Введите дату!")
            return
        
        if not self.validate_date(date):
            messagebox.showerror("Ошибка", "Неверный формат даты!\nИспользуйте формат: ГГГГ-ММ-ДД")
            return
        
        # Создание записи
        expense = {
            "date": date,
            "amount": amount,
            "category": category,
            "description": description if description else "",
            "added_date": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        }
        
        self.expenses.append(expense)
        self.save_expenses()
        
        # Очистка полей и обновление
        self.clear_fields()
        self.display_expenses()
        self.update_total()
        self.update_fast_stats()
        
        self.status_var.set(f"Расход на сумму {amount:.2f} ₽ добавлен")
        messagebox.showinfo("Успех", f"Расход на сумму {amount:.2f} ₽ успешно добавлен!")

    def delete_expense(self):
        """Удаление выбранного расхода"""
        selected = self.tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите расход для удаления!")
            return
        
        # Получение данных выбранного расхода
        item = self.tree.item(selected[0])
        values = item['values']
        
        # Поиск и удаление расхода
        for i, expense in enumerate(self.expenses):
            if (expense["date"] == values[0] and 
                expense["category"] == values[1] and 
                abs(expense["amount"] - float(values[2].replace(",", ""))) < 0.01):
                
                if messagebox.askyesno("Подтверждение", 
                                      f"Удалить расход:\n{expense['date']} - {expense['category']} - {expense['amount']:.2f} ₽"):
                    del self.expenses[i]
                    self.save_expenses()
                    self.display_expenses()
                    self.update_total()
                    self.update_fast_stats()
                    self.filter_and_calculate()  # Обновляем фильтры
                    self.status_var.set("Расход удалён")
                    break

    def edit_expense(self):
        """Редактирование выбранного расхода"""
        selected = self.tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите расход для редактирования!")
            return
        
        # Получение данных
        item = self.tree.item(selected[0])
        values = item['values']
        
        # Поиск расхода для редактирования
        for i, expense in enumerate(self.expenses):
            if (expense["date"] == values[0] and 
                expense["category"] == values[1] and 
                abs(expense["amount"] - float(values[2].replace(",", ""))) < 0.01):
                
                # Создание окна редактирования
                edit_window = tk.Toplevel(self.root)
                edit_window.title("Редактирование расхода")
                edit_window.geometry("450x450")
                edit_window.resizable(False, False)
                edit_window.transient(self.root)
                edit_window.grab_set()
                
                # Поля для редактирования
                ttk.Label(edit_window, text="Сумма (₽):", font=("Arial", 10, "bold")).pack(pady=(15, 5))
                amount_edit = ttk.Entry(edit_window, width=35, font=("Arial", 11))
                amount_edit.insert(0, str(expense["amount"]))
                amount_edit.pack(pady=(0, 15))
                
                ttk.Label(edit_window, text="Категория:", font=("Arial", 10, "bold")).pack(pady=(5, 5))
                category_edit = ttk.Combobox(edit_window, values=self.categories, width=32, state="readonly")
                category_edit.set(expense["category"])
                category_edit.pack(pady=(0, 15))
                
                ttk.Label(edit_window, text="Дата (ГГГГ-ММ-ДД):", font=("Arial", 10, "bold")).pack(pady=(5, 5))
                date_edit = ttk.Entry(edit_window, width=35, font=("Arial", 11))
                date_edit.insert(0, expense["date"])
                date_edit.pack(pady=(0, 15))
                
                ttk.Label(edit_window, text="Описание:", font=("Arial", 10, "bold")).pack(pady=(5, 5))
                desc_edit = tk.Text(edit_window, height=4, width=35, wrap=tk.WORD)
                desc_edit.insert("1.0", expense.get("description", ""))
                desc_edit.pack(pady=(0, 15))
                
                def save_edit():
                    # Валидация
                    new_amount_str = amount_edit.get().strip()
                    new_category = category_edit.get()
                    new_date = date_edit.get().strip()
                    new_desc = desc_edit.get("1.0", tk.END).strip()
                    
                    try:
                        new_amount = float(new_amount_str)
                        if new_amount <= 0:
                            messagebox.showerror("Ошибка", "Сумма должна быть положительным числом!")
                            return
                    except ValueError:
                        messagebox.showerror("Ошибка", "Сумма должна быть числом!")
                        return
                    
                    if not new_category:
                        messagebox.showerror("Ошибка", "Выберите категорию!")
                        return
                    
                    if not new_date:
                        messagebox.showerror("Ошибка", "Введите дату!")
                        return
                    
                    if not self.validate_date(new_date):
                        messagebox.showerror("Ошибка", "Неверный формат даты!")
                        return
                    
                    # Обновление расхода
                    expense["amount"] = new_amount
                    expense["category"] = new_category
                    expense["date"] = new_date
                    expense["description"] = new_desc
                    expense["added_date"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                    
                    self.save_expenses()
                    self.display_expenses()
                    self.update_total()
                    self.update_fast_stats()
                    self.filter_and_calculate()
                    edit_window.destroy()
                    self.status_var.set("Расход обновлён")
                    messagebox.showinfo("Успех", "Расход успешно обновлён!")
                
                ttk.Button(edit_window, text="💾 Сохранить", command=save_edit).pack(pady=(10, 5))
                ttk.Button(edit_window, text="❌ Отмена", command=edit_window.destroy).pack()
                
                break

    def clear_fields(self):
        """Очистка полей ввода"""
        self.amount_entry.delete(0, tk.END)
        self.category_combo.set("Выберите категорию")
        self.date_entry.delete(0, tk.END)
        self.date_entry.insert(0, datetime.now().strftime("%Y-%m-%d"))
        self.desc_text.delete("1.0", tk.END)

def main():
    root = tk.Tk()
    app = ExpenseTracker(root)
    root.mainloop()

if __name__ == "__main__":
    main()
