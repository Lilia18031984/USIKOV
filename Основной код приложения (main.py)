import tkinter as tk
from tkinter import ttk, messagebox
import json
import urllib.request
import urllib.error
from datetime import datetime
import threading

class GitHubUserFinder:
    """Приложение для поиска пользователей GitHub"""
    
    def __init__(self):
        # Загрузка избранных пользователей
        self.favorites = self.load_favorites()
        
        # Создание главного окна
        self.window = tk.Tk()
        self.window.title("🐙 GitHub User Finder")
        self.window.geometry("900x650")
        self.window.resizable(False, False)
        self.window.configure(bg="#0d1117")
        
        # Центрирование окна
        self.center_window()
        
        # Создание интерфейса
        self.create_widgets()
        
        # Обновление списка избранных
        self.update_favorites_list()
        
        # Обработка закрытия окна
        self.window.protocol("WM_DELETE_WINDOW", self.on_closing)
    
    def center_window(self):
        """Центрирует окно на экране"""
        self.window.update_idletasks()
        width = 900
        height = 650
        x = (self.window.winfo_screenwidth() // 2) - (width // 2)
        y = (self.window.winfo_screenheight() // 2) - (height // 2)
        self.window.geometry(f"{width}x{height}+{x}+{y}")
    
    def load_favorites(self):
        """Загружает избранных пользователей из JSON-файла"""
        try:
            with open("favorites.json", "r", encoding="utf-8") as file:
                favorites = json.load(file)
                if isinstance(favorites, list):
                    return favorites
                return []
        except FileNotFoundError:
            return []
        except json.JSONDecodeError:
            messagebox.showerror("Ошибка", "Файл favorites.json повреждён")
            return []
    
    def save_favorites(self):
        """Сохраняет избранных пользователей в JSON-файл"""
        try:
            with open("favorites.json", "w", encoding="utf-8") as file:
                json.dump(self.favorites, file, ensure_ascii=False, indent=4)
            return True
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось сохранить: {e}")
            return False
    
    def create_widgets(self):
        """Создаёт все виджеты интерфейса"""
        
        # Заголовок
        title_frame = tk.Frame(self.window, bg="#0d1117")
        title_frame.pack(fill="x", pady=(15, 10), padx=20)
        
        title_label = tk.Label(
            title_frame,
            text="🐙 GitHub User Finder",
            font=("Segoe UI", 20, "bold"),
            bg="#0d1117",
            fg="#ffffff"
        )
        title_label.pack()
        
        subtitle_label = tk.Label(
            title_frame,
            text="Поиск пользователей GitHub и сохранение в избранное",
            font=("Segoe UI", 10),
            bg="#0d1117",
            fg="#8b949e"
        )
        subtitle_label.pack()
        
        # Панель поиска
        search_frame = tk.Frame(self.window, bg="#0d1117")
        search_frame.pack(fill="x", pady=15, padx=20)
        
        tk.Label(
            search_frame,
            text="🔍 Поиск пользователя:",
            font=("Segoe UI", 11, "bold"),
            bg="#0d1117",
            fg="#c9d1d9"
        ).pack(anchor="w", pady=(0, 5))
        
        entry_frame = tk.Frame(search_frame, bg="#0d1117")
        entry_frame.pack(fill="x")
        
        self.search_entry = tk.Entry(
            entry_frame,
            font=("Segoe UI", 12),
            bg="#161b22",
            fg="#c9d1d9",
            relief="flat",
            insertbackground="#c9d1d9"
        )
        self.search_entry.pack(side="left", fill="x", expand=True, padx=(0, 10))
        
        self.search_button = tk.Button(
            entry_frame,
            text="Поиск",
            command=self.search_user,
            bg="#238636",
            fg="white",
            font=("Segoe UI", 10, "bold"),
            relief="flat",
            cursor="hand2",
            padx=20,
            pady=5
        )
        self.search_button.pack(side="right")
        
        self.search_button.bind("<Enter>", lambda e: self.search_button.config(bg="#2ea043"))
        self.search_button.bind("<Leave>", lambda e: self.search_button.config(bg="#238636"))
        
        # Основной фрейм
        main_frame = tk.Frame(self.window, bg="#0d1117")
        main_frame.pack(fill="both", expand=True, padx=20, pady=(0, 15))
        
        # Левая панель - результаты поиска
        left_frame = tk.Frame(main_frame, bg="#0d1117")
        left_frame.pack(side="left", fill="both", expand=True, padx=(0, 10))
        
        tk.Label(
            left_frame,
            text="📋 РЕЗУЛЬТАТЫ ПОИСКА",
            font=("Segoe UI", 12, "bold"),
            bg="#0d1117",
            fg="#ffffff"
        ).pack(anchor="w", pady=(0, 8))
        
        # Treeview для результатов
        columns = ("avatar", "username", "name", "repos", "followers")
        self.result_tree = ttk.Treeview(
            left_frame,
            columns=columns,
            show="headings",
            height=15
        )
        
        self.result_tree.heading("avatar", text="Аватар")
        self.result_tree.heading("username", text="Логин")
        self.result_tree.heading("name", text="Имя")
        self.result_tree.heading("repos", text="Репозитории")
        self.result_tree.heading("followers", text="Подписчики")
        
        self.result_tree.column("avatar", width=60, anchor="center")
        self.result_tree.column("username", width=120)
        self.result_tree.column("name", width=180)
        self.result_tree.column("repos", width=90, anchor="center")
        self.result_tree.column("followers", width=90, anchor="center")
        
        result_scrollbar = ttk.Scrollbar(left_frame, orient="vertical", command=self.result_tree.yview)
        self.result_tree.configure(yscrollcommand=result_scrollbar.set)
        
        self.result_tree.pack(side="left", fill="both", expand=True)
        result_scrollbar.pack(side="right", fill="y")
        
        # Правая панель - избранное
        right_frame = tk.Frame(main_frame, bg="#0d1117")
        right_frame.pack(side="right", fill="both", expand=True, padx=(10, 0))
        
        tk.Label(
            right_frame,
            text="⭐ ИЗБРАННЫЕ ПОЛЬЗОВАТЕЛИ",
            font=("Segoe UI", 12, "bold"),
            bg="#0d1117",
            fg="#ffffff"
        ).pack(anchor="w", pady=(0, 8))
        
        # Список избранных
        fav_frame = tk.Frame(right_frame, bg="#161b22", relief="groove", bd=1)
        fav_frame.pack(fill="both", expand=True)
        
        self.fav_listbox = tk.Listbox(
            fav_frame,
            bg="#0d1117",
            fg="#c9d1d9",
            font=("Segoe UI", 10),
            relief="flat",
            selectbackground="#1f6feb",
            height=15
        )
        self.fav_listbox.pack(side="left", fill="both", expand=True, padx=5, pady=5)
        
        fav_scrollbar = ttk.Scrollbar(fav_frame, orient="vertical", command=self.fav_listbox.yview)
        self.fav_listbox.configure(yscrollcommand=fav_scrollbar.set)
        fav_scrollbar.pack(side="right", fill="y", pady=5)
        
        # Привязка выбора в избранном
        self.fav_listbox.bind("<<ListboxSelect>>", self.on_favorite_select)
        
        # Кнопки управления
        button_frame = tk.Frame(right_frame, bg="#0d1117")
        button_frame.pack(fill="x", pady=(10, 0))
        
        self.add_fav_button = tk.Button(
            button_frame,
            text="⭐ Добавить в избранное",
            command=self.add_to_favorites,
            bg="#1f6feb",
            fg="white",
            font=("Segoe UI", 9, "bold"),
            relief="flat",
            cursor="hand2"
        )
        self.add_fav_button.pack(side="left", padx=(0, 5), expand=True, fill="x")
        
        self.remove_fav_button = tk.Button(
            button_frame,
            text="🗑️ Удалить из избранного",
            command=self.remove_from_favorites,
            bg="#da3633",
            fg="white",
            font=("Segoe UI", 9, "bold"),
            relief="flat",
            cursor="hand2"
        )
        self.remove_fav_button.pack(side="left", expand=True, fill="x")
        
        # Детальная информация
        detail_frame = tk.Frame(right_frame, bg="#161b22", relief="groove", bd=1)
        detail_frame.pack(fill="x", pady=(10, 0))
        
        tk.Label(
            detail_frame,
            text="ℹ️ ИНФОРМАЦИЯ",
            font=("Segoe UI", 10, "bold"),
            bg="#161b22",
            fg="#c9d1d9"
        ).pack(pady=(8, 5))
        
        self.detail_text = tk.Text(
            detail_frame,
            bg="#0d1117",
            fg="#c9d1d9",
            font=("Segoe UI", 9),
            relief="flat",
            height=6,
            wrap=tk.WORD
        )
        self.detail_text.pack(fill="both", padx=10, pady=(0, 10))
        
        # Статусная строка
        self.status_label = tk.Label(
            self.window,
            text="💡 Введите имя пользователя GitHub для поиска",
            font=("Segoe UI", 9),
            bg="#0d1117",
            fg="#8b949e",
            anchor="w"
        )
        self.status_label.pack(side="bottom", fill="x", padx=20, pady=(0, 15))
        
        # Привязка клавиши Enter
        self.search_entry.bind("<Return>", lambda event: self.search_user())
    
    def search_user(self):
        """Поиск пользователя GitHub API"""
        username = self.search_entry.get().strip()
        
        # Проверка на пустой ввод
        if not username:
            messagebox.showwarning("Ошибка ввода", "Введите имя пользователя для поиска!")
            self.status_label.config(text="❌ Введите имя пользователя", fg="#f85149")
            self.window.after(3000, lambda: self.status_label.config(
                text="💡 Введите имя пользователя GitHub для поиска", fg="#8b949e"
            ))
            return
        
        self.status_label.config(text=f"🔍 Поиск пользователя '{username}'...", fg="#f0883e")
        self.search_button.config(state="disabled", text="Поиск...")
        
        # Запуск поиска в отдельном потоке
        thread = threading.Thread(target=self.fetch_user_data, args=(username,))
        thread.daemon = True
        thread.start()
    
    def fetch_user_data(self, username):
        """Запрос данных пользователя из GitHub API"""
        try:
            # Запрос к GitHub API
            url = f"https://api.github.com/users/{username}"
            req = urllib.request.Request(url)
            req.add_header("User-Agent", "GitHub-User-Finder-App")
            
            with urllib.request.urlopen(req, timeout=10) as response:
                data = json.loads(response.read().decode())
                self.window.after(0, lambda: self.display_user_data(data))
                self.window.after(0, lambda: self.status_label.config(
                    text=f"✅ Найден пользователь: {username}", fg="#3fb950"
                ))
                self.window.after(3000, lambda: self.status_label.config(
                    text="💡 Готов к новому поиску", fg="#8b949e"
                ))
                
        except urllib.error.HTTPError as e:
            if e.code == 404:
                self.window.after(0, lambda: messagebox.showerror(
                    "Ошибка", f"Пользователь '{username}' не найден!"
                ))
                self.window.after(0, lambda: self.status_label.config(
                    text=f"❌ Пользователь '{username}' не найден", fg="#f85149"
                ))
            else:
                self.window.after(0, lambda: messagebox.showerror(
                    "Ошибка", f"Ошибка API: {e.code}"
                ))
        except urllib.error.URLError:
            self.window.after(0, lambda: messagebox.showerror(
                "Ошибка", "Нет подключения к интернету!"
            ))
            self.window.after(0, lambda: self.status_label.config(
                text="❌ Нет подключения к интернету", fg="#f85149"
            ))
        except Exception as e:
            self.window.after(0, lambda: messagebox.showerror(
                "Ошибка", f"Произошла ошибка: {str(e)}"
            ))
        finally:
            self.window.after(0, lambda: self.search_button.config(state="normal", text="Поиск"))
    
    def display_user_data(self, data):
        """Отображает данные пользователя в Treeview"""
        # Очищаем предыдущие результаты
        for item in self.result_tree.get_children():
            self.result_tree.delete(item)
        
        # Получаем данные
        avatar = "🖼️"
        username = data.get('login', 'N/A')
        name = data.get('name', 'Не указано')
        repos = data.get('public_repos', 0)
        followers = data.get('followers', 0)
        
        self.result_tree.insert("", "end", values=(
            avatar, username, name, repos, followers
        ))
        
        # Сохраняем данные текущего пользователя
        self.current_user = {
            "username": username,
            "name": name if name != "Не указано" else username,
            "avatar_url": data.get('avatar_url', ''),
            "repos": repos,
            "followers": followers,
            "following": data.get('following', 0),
            "location": data.get('location', 'Не указано'),
            "company": data.get('company', 'Не указано'),
            "blog": data.get('blog', 'Не указано'),
            "bio": data.get('bio', 'Нет описания'),
            "url": data.get('html_url', ''),
            "created_at": data.get('created_at', 'Не указано').split('T')[0]
        }
        
        # Обновляем детальную информацию
        self.update_detail_info(self.current_user)
    
    def update_detail_info(self, user):
        """Обновляет панель с детальной информацией"""
        self.detail_text.delete(1.0, tk.END)
        
        info = f"""👤 Логин: {user['username']}
📛 Имя: {user['name']}
📍 Локация: {user['location']}
🏢 Компания: {user['company']}
📝 О себе: {user['bio'][:100]}...
📊 Репозитории: {user['repos']}
👥 Подписчики: {user['followers']}
👣 Подписки: {user['following']}
📅 Дата регистрации: {user['created_at']}"""
        
        self.detail_text.insert(1.0, info)
    
    def add_to_favorites(self):
        """Добавляет выбранного пользователя в избранное"""
        if not hasattr(self, 'current_user'):
            messagebox.showwarning("Предупреждение", "Сначала найдите пользователя!")
            return
        
        # Проверка на дубликаты
        for fav in self.favorites:
            if fav["username"] == self.current_user["username"]:
                messagebox.showwarning(
                    "Предупреждение", 
                    f"Пользователь '{self.current_user['username']}' уже в избранном!"
                )
                return
        
        # Добавляем пользователя в избранное
        user_data = {
            "username": self.current_user["username"],
            "name": self.current_user["name"],
            "avatar_url": self.current_user["avatar_url"],
            "added_date": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        }
        self.favorites.append(user_data)
        self.save_favorites()
        self.update_favorites_list()
        
        self.status_label.config(
            text=f"⭐ Пользователь '{self.current_user['username']}' добавлен в избранное", 
            fg="#3fb950"
        )
        self.window.after(3000, lambda: self.status_label.config(
            text="💡 Готов к работе", fg="#8b949e"
        ))
    
    def remove_from_favorites(self):
        """Удаляет выбранного пользователя из избранного"""
        selected = self.fav_listbox.curselection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите пользователя из списка избранных!")
            return
        
        index = selected[0]
        username = self.favorites[index]["username"]
        
        if messagebox.askyesno("Подтверждение", f"Удалить '{username}' из избранного?"):
            self.favorites.pop(index)
            self.save_favorites()
            self.update_favorites_list()
            
            # Очищаем детальную информацию, если она была об этом пользователе
            if hasattr(self, 'current_user') and self.current_user["username"] == username:
                self.detail_text.delete(1.0, tk.END)
            
            self.status_label.config(text=f"🗑️ Пользователь '{username}' удалён из избранного", fg="#f85149")
            self.window.after(3000, lambda: self.status_label.config(
                text="💡 Готов к работе", fg="#8b949e"
            ))
    
    def on_favorite_select(self, event):
        """Обработка выбора пользователя из избранного"""
        selected = self.fav_listbox.curselection()
        if not selected:
            return
        
        index = selected[0]
        user = self.favorites[index]
        username = user["username"]
        
        # Загружаем актуальные данные пользователя
        self.search_entry.delete(0, tk.END)
        self.search_entry.insert(0, username)
        self.search_user()
    
    def update_favorites_list(self):
        """Обновляет отображение списка избранных"""
        self.fav_listbox.delete(0, tk.END)
        for fav in self.favorites:
            display_text = f"⭐ {fav['username']} — {fav['name']}"
            self.fav_listbox.insert(tk.END, display_text)
    
    def on_closing(self):
        """Обработка закрытия окна"""
        if self.save_favorites():
            self.window.destroy()
    
    def run(self):
        """Запуск приложения"""
        self.window.mainloop()

# Запуск программы
if __name__ == "__main__":
    app = GitHubUserFinder()
    app.run()
